# ===== 夸克签到 Web 服务 环境变量 =====
# 复制本文件为 .env 并填入你自己的值（.env 已被 .gitignore 忽略，不会提交）

# 定时签到时间（24小时制，北京时间）
SIGN_HOUR=0
SIGN_MINUTE=30

# Server酱 SendKey（https://sct.ftqq.com/ 获取）
# 留空则不进行推送通知；也可在网页「定时设置」中随时修改
SERVERCHAN_SENDKEY=

# 通知模式: all(每次签到都通知) / fail(仅失败时通知) / success(仅成功时通知)
NOTIFY_MODE=all

# 服务监听端口
PORT=5000
